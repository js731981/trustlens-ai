# Vector store: ":memory:" needs no extra process (data is lost when the process exits).
# For persistence, run Qdrant and point here, e.g. `docker run -p 6333:6333 qdrant/qdrant`
# then set QDRANT_URL=http://127.0.0.1:6333
QDRANT_URL=:memory:
QDRANT_API_KEY=

# Collection name (created on startup if missing)
QDRANT_COLLECTION=rag_documents

# sentence-transformers model (vector size must match collection; default is 384-dim)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API
ENVIRONMENT=development
