APP_NAME=Trust Lens API
# Set to DEV to skip LLM calls and return an instant mock (frontend / pipeline testing).
# ENV=DEV
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
# Streamlit UI (streamlit_app.py) — optional override for API location
TRUST_LENS_API_BASE=http://127.0.0.1:8000
# SQLite + logs: LLM rows, trust history, drift (default ./data)
# TRUST_LENS_DATA_DIR=data

# RAG service (analyze route: POST {RAG_SERVICE_BASE_URL}/search before LLM)
# RAG_SERVICE_BASE_URL=http://localhost:8002
# RAG_SEARCH_TOP_K=10
# RAG_SERVICE_TIMEOUT_SECONDS=10

# LLM Providers
# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=phi3
# OLLAMA_FALLBACK_MODEL=
# OLLAMA_STREAM=false

# OpenAI
OPENAI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
